# Build output
/build/bin/

# Vite output. frontend/dist/gitkeep stays tracked: main.go has
# //go:embed all:frontend/dist, which fails to compile if the directory does not
# exist — so a fresh clone must still have it before the frontend is built.
/frontend/dist/*
!/frontend/dist/gitkeep

/frontend/node_modules/

# Generated by `wails build` / `wails generate module` from the bound Go
# structs. Committed so the frontend typechecks in a fresh clone before any Go
# build has run.
# (Remove this comment and the ! lines if you would rather generate on demand.)

# Editors
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
