# Build output
/build/bin/

# Vite output.
#
# frontend/dist/gitkeep MUST stay tracked: main.go has
# //go:embed all:frontend/dist, which refuses to compile when the directory is
# missing or empty. Without it, `go build`, `go vet` and `go test` all fail on a
# fresh clone before the frontend has ever been built.
#
# Vite empties dist/ on every build, so the placeholder cannot simply be
# committed and forgotten — it would vanish the first time anyone built. It is
# restored by frontend/public/gitkeep, which Vite copies back into dist/ after
# emptying it. Delete either one and CI breaks on the next fresh checkout.
/frontend/dist/*
!/frontend/dist/gitkeep

/frontend/node_modules/

# Editors
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
